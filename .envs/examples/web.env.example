PUBLIC_WALLET_CONNECT_PROJECT_ID=

# Etherscan V2 API keys (single key works across all 60+ chains)
# Comma-separated for rotation to avoid rate limits
ETHERSCAN_API_KEYS=

PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=



# Supabase service role key (server-side only, for API writes)
SUPABASE_SERVICE_ROLE_KEY=

SUPABASE_DATABASE_URI=


FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=

FLUTTERWAVE_CLIENT_ID=
FLUTTERWAVE_V4_CLIENT_SECRET=
FLUTTERWAVE_V4_ENCRYPTION_KEY=

# Payment details encryption (AES-256-GCM, 64-char hex = 32 bytes)
ENCRYPTION_KEY=

# Admin wallets (comma-separated, for withdrawal processing + status updates)
# These wallets can perform admin actions by signing messages
ADMIN_WALLETS=

# Allowed origins for signature verification (comma-separated)
# Prevents phishing sites from reusing signatures meant for your domain
ALLOWED_ORIGINS=

# Daemon/sync endpoint auth
SYNC_SECRET=
WALLET_SECRET=

ADMIN_KEY=
TX_CONFIRM_SECRET=
PAYMENT_PROXY_URL=


BUSHA_SECRET_KEY=
CONFIRM_TO_ADDRESS=

FLUTTERWAVE_WEBHOOK_SECRET=

# Telegram alerts (BotFather token + chat/channel id; channel ids are negative)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
