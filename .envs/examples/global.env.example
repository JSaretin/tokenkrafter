# Shared across all daemons. Compose loads this BEFORE each service's
# own env file so service-specific values still override.
#
# Copy to ../prod/global.env (or ../dev/global.env) and fill in.

# Daemons load every enabled chain from /api/config?keys=networks at
# startup — no CHAIN_ID/RPC_URL needed here. Per-chain RPC + contract
# addresses live in platform_config.networks.

# SvelteKit backend the daemons call back into.
API_BASE_URL=https://tokenkrafter.com

# Redis (compose-internal hostname).
REDIS_URL=redis://redis:6379

# Vault payment auth (proxy + processor + onramp + web).
TX_CONFIRM_SECRET=

# Flutterwave v3 (NGN balance + transfers).
FLUTTERWAVE_SECRET_KEY=

# BscScan / Etherscan v2 (verifier).
ETHERSCAN_API_KEYS=
