# ── WalletConnect / Reown AppKit ──
PUBLIC_WALLET_CONNECT_PROJECT_ID=

# ── Etherscan V2 (works across all supported chains) ──
# Comma-separated for rotation to avoid rate limits.
ETHERSCAN_API_KEYS=
ETHERSCAN_API_KEY=

# ── Supabase ──
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DATABASE_URI=

# ── Flutterwave (fiat off-ramp) ──
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=
FLUTTERWAVE_CLIENT_ID=
FLUTTERWAVE_CLIENT_SECRET=
FLUTTERWAVE_WEBHOOK_SECRET=

# ── Admin / off-ramp signer ──
# Admin wallet private key for calling TradeRouter.confirm() /refund().
# Address is derived from this at runtime.
ADMIN_KEY=

# ── Cross-service secrets ──
# Shared secret between withdrawal-processor and /api/withdrawals/process.
TX_CONFIRM_SECRET=
# Shared secret between daemon syncers and /api/sync endpoints.
SYNC_SECRET=
