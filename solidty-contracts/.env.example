# Deployer wallet (funds deploy + pays gas).
DEPLOYER_PRIVATE_KEY=

# Explorer API keys for contract verification.
# Etherscan V2 covers BscScan with the same key.
BSCSCAN_API_KEY=
ETHERSCAN_API_KEY=
ETHERSCAN_API_KEYS=

# Platform fee recipient (defaults to deployer if unset).
PLATFORM_WALLET=

# Optional RPC overrides. BSC_RPC_URL is also settable via scripts/deploy-bsc.mjs
# which pulls daemon_rpc from Supabase.
BSC_RPC_URL=
BSC_TESTNET_RPC_URL=
ETH_RPC_URL=
SEPOLIA_RPC_URL=

# Optional: force-archive existing deployment addresses as *_Old on rerun.
DEPLOY_FRESH=0
