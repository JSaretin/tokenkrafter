# Supabase CLI auto-loads this file when starting the local stack.
# Copy to supabase/.env and fill in real values.
# config.toml references these via env(VAR_NAME).

# Google OAuth client secret. Get from Google Cloud Console → Credentials.
# For solo dev you can use the same client as prod; for stricter isolation,
# create a separate "dev" OAuth client and use that secret here.
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
